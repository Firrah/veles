[gd_scene format=3 uid="uid://db8ie0d78wbic"]

[sub_resource type="GDScript" id="GDScript_mh0ok"]
script/source = "extends Node2D

# ==========================================
# ENUMS & КОНСТАНТЫ НАСТРОЙКИ
# ==========================================
enum CombatMode { COMBAT, PEACE }
var current_combat_mode = CombatMode.COMBAT
var chosen_path_name: String = \"Выбор не сделан\"

# Размеры расширенной карты
var map_width: float = 3200.0
var map_height: float = 2000.0

# Глобальные параметры персонажа и Прогресс
var max_hp: float = 100.0
var current_hp: float = 100.0
var max_mp: float = 100.0
var current_mp: float = 100.0
var mp_spell_cost: float = 30.0
var mp_regen_speed_yav: float = 15.0
var mp_regen_speed_nav: float = 5.0

# Система Опыта (Исследования)
var player_level: int = 1
var player_xp: int = 0
var xp_to_next_level: int = 100

# Инвентарь игрока
var inventory = {
	\"crystal\": 0,
	\"herb\": 0
}

var max_nav_time: float = 15.0
var current_nav_time: float = 15.0
var is_nav_world: bool = false
var current_location_name: String = \"Окраина Чернолесья\"
var can_pick_up_crystal: bool = false

# Прогресс обучения
var tutorial_steps_done = {\"move\": false, \"roll\": false, \"nav\": false}

# Модификаторы ИИ
var enemy_speed_modifier: float = 1.0
var enemy_damage_modifier: float = 1.0

# Ссылки на ключевые узлы
var player: CharacterBody2D
var player_sprite: Sprite2D
var background: TextureRect
var canvas_modulate: CanvasModulate
var camera: Camera2D

# Ссылки на UI элементы HUD
var world_label: Label
var hp_beads_container: HBoxContainer
var mp_bar: ProgressBar
var nav_label: Label
var dialogue_panel: Panel
var dialogue_text: Label
var dialogue_choices: Label
var xp_label: Label

# Миникарта
var minimap_panel: Panel
var minimap_content: Control

# Элементы Системы Квестов и Инвентаря
var quest_panel: Panel
var quest_text: Label
var inv_panel: Panel
var inv_slots_text: Label

# Настройки перемещения
var player_speed: float = 250.0
var roll_speed: float = 550.0
var roll_duration: float = 0.2
var is_rolling: bool = false
var roll_timer: float = 0.0
var roll_direction: Vector2 = Vector2.ZERO
var attack_cooldown: bool = false

# Массивы динамических объектов
var enemy_list = []
var active_projectiles = []
var level_objects = []

# ==========================================
# ИНИЦИАЛИЗАЦИЯ
# ==========================================
func _ready() -> void:
	setup_window()
	setup_input_map()
	
	background = TextureRect.new()
	background.size = Vector2(map_width, map_height)
	background.expand_mode = TextureRect.EXPAND_IGNORE_SIZE
	add_child(background)
	
	canvas_modulate = CanvasModulate.new()
	canvas_modulate.color = Color(1, 1, 1)
	add_child(canvas_modulate)
	
	build_player()
	build_advanced_hud()
	build_minimap_ui()
	build_quest_and_inventory_ui()
	
	load_location(\"Окраина Чернолесья\") # Начинаем с обучения!

func setup_window() -> void:
	DisplayServer.window_set_mode(DisplayServer.WINDOW_MODE_EXCLUSIVE_FULLSCREEN)
	get_tree().root.content_scale_mode = Window.CONTENT_SCALE_MODE_VIEWPORT
	get_tree().root.content_scale_aspect = Window.CONTENT_SCALE_ASPECT_KEEP
	get_tree().root.content_scale_size = Vector2i(1920, 1080)

func setup_input_map() -> void:
	var inputs = {
		\"move_left\": [KEY_A, KEY_LEFT],
		\"move_right\": [KEY_D, KEY_RIGHT],
		\"move_up\": [KEY_W, KEY_UP],
		\"move_down\": [KEY_S, KEY_DOWN],
		\"switch_world\": [KEY_R],
		\"roll\": [KEY_SHIFT],
		\"attack\": [KEY_SPACE, MOUSE_BUTTON_LEFT],
		\"cast_spell\": [KEY_Q],
		\"choice1\": [KEY_1],
		\"choice2\": [KEY_2],
		\"choice3\": [KEY_3]
	}
	for action in inputs:
		if not InputMap.has_action(action):
			InputMap.add_action(action)
			for key in inputs[action]:
				var event
				if action == \"attack\" and key == MOUSE_BUTTON_LEFT:
					event = InputEventMouseButton.new()
					event.button_index = MOUSE_BUTTON_LEFT
				else:
					event = InputEventKey.new()
					event.physical_keycode = key
				InputMap.action_add_event(action, event)

func load_texture_safe(path: String, fallback_size: Vector2, fallback_color: Color) -> Texture2D:
	if ResourceLoader.exists(path):
		var tex = load(path)
		if tex is Texture2D: return tex
	var img := Image.create(int(fallback_size.x), int(fallback_size.y), false, Image.FORMAT_RGBA8)
	img.fill(fallback_color)
	return ImageTexture.create_from_image(img)

# ==========================================
# СБОРКА ПЕРСОНАЖА И КАМЕРЫ
# ==========================================
func build_player() -> void:
	player = CharacterBody2D.new()
	player.position = Vector2(300, 300)
	
	player_sprite = Sprite2D.new()
	player_sprite.texture = load_texture_safe(\"res://player.png\", Vector2(64, 96), Color(0.8, 0.8, 0.8))
	player.add_child(player_sprite)
	
	var shape := CollisionShape2D.new()
	shape.shape = RectangleShape2D.new()
	shape.shape.size = Vector2(50, 80)
	player.add_child(shape)
	
	# Камера следования за игроком на большой карте
	camera = Camera2D.new()
	camera.position_smoothing_enabled = true
	camera.position_smoothing_speed = 6.0
	camera.limit_left = 0
	camera.limit_top = 0
	camera.limit_right = int(map_width)
	camera.limit_bottom = int(map_height)
	player.add_child(camera)
	
	add_child(player)
	start_idle_animation(player_sprite)

# ==========================================
# СОЗДАНИЕ УЛУЧШЕННОГО ИНТЕРФЕЙСА (HUD)
# ==========================================
func build_advanced_hud() -> void:
	var canvas_layer := CanvasLayer.new()
	canvas_layer.name = \"HUDLayer\"
	add_child(canvas_layer)
	
	var status_panel := Panel.new()
	status_panel.position = Vector2(210, 30) # Смещено вправо, освобождая место миникарте
	status_panel.size = Vector2(400, 165)
	
	var style = StyleBoxFlat.new()
	style.bg_color = Color(0.09, 0.07, 0.06, 0.85)
	style.border_width_left = 3; style.border_width_top = 3; style.border_width_right = 3; style.border_width_bottom = 3
	style.border_color = Color(0.83, 0.68, 0.21)
	style.corner_radius_top_left = 6; style.corner_radius_bottom_right = 6
	status_panel.add_theme_stylebox_override(\"panel\", style)
	canvas_layer.add_child(status_panel)
	
	world_label = Label.new()
	world_label.position = Vector2(15, 12)
	world_label.add_theme_color_override(\"font_color\", Color(0.98, 0.88, 0.5))
	status_panel.add_child(world_label)
	
	var hp_title := Label.new()
	hp_title.position = Vector2(15, 52)
	hp_title.text = \"Жизнь:\"
	status_panel.add_child(hp_title)
	
	hp_beads_container = HBoxContainer.new()
	hp_beads_container.position = Vector2(90, 54)
	hp_beads_container.add_theme_constant_override(\"separation\", 8)
	status_panel.add_child(hp_beads_container)
	
	var mp_title := Label.new()
	mp_title.position = Vector2(15, 90)
	mp_title.text = \"Дух:\"
	status_panel.add_child(mp_title)
	
	mp_bar = ProgressBar.new()
	mp_bar.position = Vector2(90, 93)
	mp_bar.size = Vector2(280, 14)
	mp_bar.max_value = max_mp
	mp_bar.value = current_mp
	mp_bar.show_percentage = false
	var mp_fill = StyleBoxFlat.new()
	mp_fill.bg_color = Color(0.12, 0.56, 0.65)
	mp_bar.add_theme_stylebox_override(\"fill\", mp_fill)
	status_panel.add_child(mp_bar)
	
	xp_label = Label.new()
	xp_label.position = Vector2(15, 128)
	xp_label.text = \"Уровень: 1 (0 / 100 XP)\"
	xp_label.add_theme_color_override(\"font_color\", Color(0.3, 0.8, 0.3))
	status_panel.add_child(xp_label)
	
	nav_label = Label.new()
	nav_label.position = Vector2(200, 128)
	nav_label.add_theme_color_override(\"font_color\", Color(0.45, 0.65, 1.0))
	nav_label.text = \"Навь: 15.0с\"
	nav_label.visible = false
	status_panel.add_child(nav_label)
	
	# Диалоговое окно
	dialogue_panel = Panel.new()
	dialogue_panel.position = Vector2(360, 760)
	dialogue_panel.size = Vector2(1200, 180)
	dialogue_panel.visible = false
	var diag_style = StyleBoxFlat.new()
	diag_style.bg_color = Color(0.06, 0.06, 0.08, 0.95)
	diag_style.border_width_top = 4; diag_style.border_color = Color(0.83, 0.68, 0.21)
	dialogue_panel.add_theme_stylebox_override(\"panel\", diag_style)
	canvas_layer.add_child(dialogue_panel)
	
	dialogue_text = Label.new()
	dialogue_text.position = Vector2(40, 25); dialogue_text.size = Vector2(1120, 70)
	dialogue_text.autowrap_mode = TextServer.AUTOWRAP_WORD
	dialogue_panel.add_child(dialogue_text)
	
	dialogue_choices = Label.new()
	dialogue_choices.position = Vector2(40, 115); dialogue_choices.size = Vector2(1120, 50)
	dialogue_choices.add_theme_color_override(\"font_color\", Color.GOLD)
	dialogue_panel.add_child(dialogue_choices)
	
	update_hp_display()

# ==========================================
# МЕХАНИКА МИНИКАРТЫ (РАДАР КЛЮЧЕВЫХ ОБЪЕКТОВ)
# ==========================================
func build_minimap_ui() -> void:
	var canvas = $HUDLayer
	minimap_panel = Panel.new()
	minimap_panel.position = Vector2(30, 30)
	minimap_panel.size = Vector2(165, 165)
	
	var m_style = StyleBoxFlat.new()
	m_style.bg_color = Color(0.05, 0.05, 0.05, 0.9)
	m_style.border_width_left = 2; m_style.border_width_top = 2; m_style.border_width_right = 2; m_style.border_width_bottom = 2
	m_style.border_color = Color(0.6, 0.5, 0.2)
	minimap_panel.add_theme_stylebox_override(\"panel\", m_style)
	canvas.add_child(minimap_panel)
	
	minimap_content = Control.new()
	minimap_content.position = Vector2(0, 0)
	minimap_content.size = Vector2(165, 165)
	minimap_panel.add_child(minimap_content)

func update_minimap() -> void:
	if not is_instance_valid(minimap_content): return
	for n in minimap_content.get_children(): n.queue_free()
	
	if not is_instance_valid(player): return
	
	# Отрисовка маркера игрока (Белый круг по центру)
	var p_dot := ColorRect.new()
	p_dot.size = Vector2(6, 6)
	p_dot.position = Vector2(82, 82)
	p_dot.color = Color.WHITE
	minimap_content.add_child(p_dot)
	
	# Сканирование окружения (Ограничено радиусом отображения радара)
	var radar_scale = 0.06 # Коэффициент сжатия координат мира под радар
	
	for obj in level_objects:
		if is_instance_valid(obj):
			var offset = (obj.position - player.position) * radar_scale
			var map_pos = Vector2(82, 82) + offset
			
			# Рисуем маркер только если он помещается в границы миникарты
			if map_pos.x > 4 and map_pos.x < 160 and map_pos.y > 4 and map_pos.y < 160:
				var dot := ColorRect.new()
				dot.size = Vector2(5, 5)
				dot.position = map_pos
				
				if enemy_list.has(obj):
					dot.color = Color.RED if obj.visible else Color(0.3, 0.2, 0.7, 0.4) # Враги Яви/Нави
				elif obj.has_meta(\"type\") and obj.get_meta(\"type\") == \"crystal\":
					dot.color = Color.CYAN # Кристаллы Велеса
				elif obj is Area2D and not obj.has_meta(\"type\"):
					dot.color = Color.MEDIUM_PURPLE # Портал
				else:
					continue
				minimap_content.add_child(dot)

# ==========================================
# ИНВЕНТАРЬ И КВЕСТЫ (ПРАВАЯ СТОРОНА)
# ==========================================
func build_quest_and_inventory_ui() -> void:
	var canvas = $HUDLayer
	
	# Свиток квестов (Вверху справа)
	quest_panel = Panel.new()
	quest_panel.position = Vector2(1460, 30)
	quest_panel.size = Vector2(430, 165)
	var q_style = StyleBoxFlat.new()
	q_style.bg_color = Color(0.06, 0.08, 0.06, 0.85)
	q_style.border_width_right = 3; q_style.border_width_bottom = 3; q_style.border_color = Color(0.5, 0.4, 0.2)
	quest_panel.add_theme_stylebox_override(\"panel\", q_style)
	canvas.add_child(quest_panel)
	
	var q_title := Label.new()
	q_title.position = Vector2(20, 12); q_title.text = \"КНИГА ЗАДАНИЙ\"; q_title.add_theme_color_override(\"font_color\", Color.GOLD)
	quest_panel.add_child(q_title)
	
	quest_text = Label.new()
	quest_text.position = Vector2(20, 45); quest_text.size = Vector2(390, 105); quest_text.autowrap_mode = TextServer.AUTOWRAP_WORD
	quest_panel.add_child(quest_text)
	
	# Панель инвентаря (Внизу справа)
	inv_panel = Panel.new()
	inv_panel.position = Vector2(1460, 840)
	inv_panel.size = Vector2(430, 180)
	var inv_style = StyleBoxFlat.new()
	inv_style.bg_color = Color(0.08, 0.07, 0.06, 0.9)
	inv_style.border_width_left = 3; inv_style.border_width_top = 3; inv_style.border_color = Color(0.7, 0.55, 0.2)
	inv_panel.add_theme_stylebox_override(\"panel\", inv_style)
	canvas.add_child(inv_panel)
	
	var inv_title := Label.new()
	inv_title.position = Vector2(20, 15); inv_title.text = \"МЕШОК С ДОБРОМ (ИНВЕНТАРЬ)\"; inv_title.add_theme_color_override(\"font_color\", Color(0.9, 0.8, 0.6))
	inv_panel.add_child(inv_title)
	
	inv_slots_text = Label.new()
	inv_slots_text.position = Vector2(20, 55); inv_slots_text.size = Vector2(390, 100)
	inv_slots_text.add_theme_color_override(\"font_color\", Color(0.95, 0.95, 0.95))
	inv_panel.add_child(inv_slots_text)
	
	update_quest_journal()
	update_inventory_ui()

func update_quest_journal() -> void:
	if not is_instance_valid(quest_text): return
	var txt = \"\"
	
	if current_location_name == \"Окраина Чернолесья\":
		txt = \"ОБУЧЕНИЕ КУДЕСНИКА:\\n\"
		txt += \"• Наступите на Шаги Обучения на земле.\\n\"
		txt += \"• Изучено: Движение (%s) | Перекат (%s) | Навь (%s)\" % [
			\"Х\" if tutorial_steps_done.move else \"О\", 
			\"Х\" if tutorial_steps_done.roll else \"О\", 
			\"Х\" if tutorial_steps_done.nav else \"О\"
		]
	else:
		txt = \"• Путь: %s\\n\" % chosen_path_name
		if inventory[\"crystal\"] >= 1:
			txt += \"• [Готово] Славянский Кристалл у вас!\\n• Ступайте в Великий Портал (справа на карте).\"
		else:
			if current_combat_mode == CombatMode.PEACE:
				txt += \"• Заберите Кристалл без битвы.\"
			elif chosen_path_name == \"Путь Теней (Скрытность)\":
				txt += \"• Аккуратно заберите Кристалл у сонного босса.\"
			else:
				txt += \"• Сразите Главного Босса, чтобы сорвать чары защиты с Кристалла.\"
				
	quest_text.text = txt

func update_inventory_ui() -> void:
	if not is_instance_valid(inv_slots_text): return
	inv_slots_text.text = \"[ Кристаллы Велеса ]:  %d шт.\\n[ Целебные Травы ]: %d шт.\" % [inventory[\"crystal\"], inventory[\"herb\"]]

func add_xp(amount: int) -> void:
	player_xp += amount
	if player_xp >= xp_to_next_level:
		player_xp -= xp_to_next_level
		player_level += 1
		max_mp += 20.0
		current_mp = max_mp
		mp_bar.max_value = max_mp
		world_label.text = \"НОВЫЙ УРОВЕНЬ ЗНАНИЙ ПРЕДКОВ!\"
	xp_label.text = \"Уровень: %d (%d / %d XP)\" % [player_level, player_xp, xp_to_next_level]

func update_hp_display() -> void:
	if not is_instance_valid(hp_beads_container): return
	for child in hp_beads_container.get_children(): child.queue_free()
	var active_beads = ceil(current_hp / 20.0)
	for i in range(5):
		var bead := ColorRect.new()
		bead.custom_minimum_size = Vector2(16, 16)
		bead.color = Color(0.75, 0.1, 0.1) if i < active_beads else Color(0.18, 0.18, 0.18, 0.5)
		hp_beads_container.add_child(bead)

# ==========================================
# ПОСТРОЕНИЕ СЦЕН И УРОВНЕЙ ИГРЫ
# ==========================================
func load_location(location_name: String) -> void:
	current_location_name = location_name
	can_pick_up_crystal = false
	current_combat_mode = CombatMode.COMBAT
	chosen_path_name = \"Выбор не сделан\"
	
	for obj in level_objects: if is_instance_valid(obj): obj.queue_free()
	level_objects.clear()
	enemy_list.clear()
	active_projectiles.clear()
	
	player.position = Vector2(250, 300)
	
	if location_name == \"Окраина Чернолесья\":
		# Карта обучения меньше размером, без мобов
		background.texture = load_texture_safe(\"res://bg_tutorial.png\", Vector2(map_width, map_height), Color(0.12, 0.14, 0.12))
		
		# Расставляем 3 древних камня обучения (зоны вех)
		spawn_tutorial_trigger(Vector2(600, 300), \"move\", \"Камень Движения: Полноценно используй клавиши WASD для исследования дремучих славянских просторов Яви.\")
		spawn_tutorial_trigger(Vector2(1200, 500), \"roll\", \"Камень Уклонения: Нажимай SHIFT во время движения. Перекат дает неуязвимость от ядер боссов.\")
		spawn_tutorial_trigger(Vector2(1800, 400), \"nav\", \"Камень Нави: Нажмите R, чтобы уйти во Тьму. Навь открывает скрытых духов и проходы, но тратит силы!\")
		
		spawn_portal(Vector2(2600, 400), \"Топи Кикиморы\")
		add_xp(50) # Бонус за начало пути
		
	elif location_name == \"Топи Кикиморы\":
		background.texture = load_texture_safe(\"res://bg_swamp.png\", Vector2(map_width, map_height), Color(0.1, 0.15, 0.11))
		
		spawn_enemy(Vector2(1500, 900), \"res://leshy.png\", Color(0.48, 0.4, 0.28), false, \"boss\")
		spawn_enemy(Vector2(900, 1400), \"res://nav_messenger.png\", Color(0.25, 0.52, 0.8), true, \"nav\")
		spawn_enemy(Vector2(2200, 600), \"res://nav_messenger.png\", Color(0.25, 0.52, 0.8), true, \"nav\")
		
		spawn_item(Vector2(1600, 950), \"crystal\", \"res://crystal.png\")
		spawn_item(Vector2(800, 400), \"herb\", \"res://herb.png\")
		spawn_item(Vector2(2400, 1500), \"herb\", \"res://herb.png\")
		spawn_portal(Vector2(3000, 1000), \"Священная Роща\")
		
		trigger_dialogue(
			\"Кикимора Топей: Стой, чужеземец Яви! Кристалл Велеса охраняем мы веками. Зачем явился с оружием к нам?\",
			\"[1] Поклониться Древним Богам (Пацифизм) | [2] Забрать силой! (Бой) | [3] Спрятаться во мгле (Скрытность)\"
		)
		add_xp(50)
		
	elif location_name == \"Священная Роща\":
		background.texture = load_texture_safe(\"res://bg_grove.png\", Vector2(map_width, map_height), Color(0.14, 0.2, 0.14))
		
		spawn_enemy(Vector2(1600, 1000), \"res://grove_guard.png\", Color(0.8, 0.6, 0.2), false, \"boss\")
		spawn_enemy(Vector2(1200, 500), \"res://chernobog_shadow.png\", Color(0.45, 0.15, 0.55), true, \"nav\")
		
		spawn_item(Vector2(1700, 1050), \"crystal\", \"res://crystal.png\")
		spawn_item(Vector2(900, 1200), \"herb\", \"res://herb.png\")
		spawn_portal(Vector2(3000, 1000), \"Финал\")
		
		trigger_dialogue(
			\"Верховный Кудесник: Свет Яви угасает в твоем сердце. Отринешь ли ты тьму Нави ради предков?\",
			\"[1] Вознести Хвалу Роду (Пацифизм) | [2] Разрубить оковы веры! (Бой) | [3] Раствориться среди деревьев (Скрытность)\"
		)
		add_xp(50)

	update_world_label_ui()
	update_quest_journal()
	switch_world(false)

func update_world_label_ui() -> void:
	var state_txt = \"НАВЬ\" if is_nav_world else \"ЯВЬ\"
	world_label.text = \"МЕСТО: %s\\nПРАВЬ/НАВЬ: %s\" % [current_location_name.to_upper(), state_txt]

# ==========================================
# СОЗДАНИЕ ВЕХ ОБУЧЕНИЯ
# ==========================================
func spawn_tutorial_trigger(pos: Vector2, step_id: String, msg: String) -> void:
	var area := Area2D.new()
	area.position = pos
	
	var spr := Sprite2D.new()
	spr.texture = load_texture_safe(\"res://stone.png\", Vector2(40, 50), Color(0.4, 0.4, 0.45))
	area.add_child(spr)
	
	var shape := CollisionShape2D.new()
	shape.shape = CircleShape2D.new(); shape.shape.radius = 70.0
	area.add_child(shape)
	
	area.body_entered.connect(func(body):
		if body == player:
			trigger_dialogue(msg, \"[1] Осознать мудрость камня\")
			tutorial_steps_done[step_id] = true
			update_quest_journal()
			add_xp(15)
	)
	add_child(area)
	level_objects.append(area)

func spawn_enemy(pos: Vector2, path: String, fallback_color: Color, nav_only: bool, id_tag: String) -> void:
	var enemy := CharacterBody2D.new()
	enemy.position = pos
	enemy.set_meta(\"nav_only\", nav_only)
	enemy.set_meta(\"id_tag\", id_tag)
	enemy.set_meta(\"hp\", 120.0 if id_tag == \"boss\" else 60.0)
	enemy.set_meta(\"status\", \"aggressive\")
	enemy.set_meta(\"attack_timer\", 0.0)
	enemy.set_meta(\"special_attack_cd\", 2.0)
	
	var spr := Sprite2D.new(); spr.name = \"Sprite2D\"
	spr.texture = load_texture_safe(path, Vector2(64, 64), fallback_color)
	enemy.add_child(spr)
	
	var shape := CollisionShape2D.new(); shape.name = \"CollisionShape2D\"
	shape.shape = RectangleShape2D.new(); shape.shape.size = Vector2(60, 60)
	enemy.add_child(shape)
	
	add_child(enemy)
	enemy_list.append(enemy)
	level_objects.append(enemy)
	start_idle_animation(spr)

func spawn_item(pos: Vector2, type: String, path: String) -> void:
	var item := Area2D.new()
	item.position = pos
	item.set_meta(\"type\", type)
	
	var spr := Sprite2D.new()
	var clr = Color(0, 0.9, 0.9) if type == \"crystal\" else Color(0.1, 0.8, 0.1)
	spr.texture = load_texture_safe(path, Vector2(32, 32), clr)
	item.add_child(spr)
	
	var shape := CollisionShape2D.new()
	shape.shape = CircleShape2D.new(); shape.shape.radius = 35.0
	item.add_child(shape)
	
	item.body_entered.connect(func(body):
		if body == player: collect_item_logic(item)
	)
	add_child(item)
	level_objects.append(item)
	start_idle_animation(spr)

func spawn_portal(pos: Vector2, target: String) -> void:
	var portal := Area2D.new()
	portal.position = pos
	
	var spr := Sprite2D.new()
	spr.texture = load_texture_safe(\"res://portal.png\", Vector2(60, 140), Color(0.6, 0.2, 0.7))
	portal.add_child(spr)
	
	var shape := CollisionShape2D.new()
	shape.shape = RectangleShape2D.new(); shape.shape.size = Vector2(60, 140)
	portal.add_child(shape)
	
	portal.body_entered.connect(func(body):
		if body == player:
			if current_location_name == \"Окраина Чернолесья\":
				if not (tutorial_steps_done.move and tutorial_steps_done.roll and tutorial_steps_done.nav):
					world_label.text = \"ПРОЙДИТЕ ВСЕ ТРИ КАМНЯ ОБУЧЕНИЯ!\"
					return
				load_location(target)
				return
				
			if target == \"Финал\":
				world_label.text = \"ПРОЕКТ ЗАВЕРШЕН. ИГРА СКОМПИЛИРОВАНА!\"
				return
			if inventory[\"crystal\"] >= 1:
				inventory[\"crystal\"] -= 1 # Забираем кристалл как плату за проход
				update_inventory_ui()
				load_location(target)
			else:
				world_label.text = \"ТРЕБУЕТСЯ КРИСТАЛЛ ЛОКАЦИИ ДЛЯ ПОРТАЛА!\"
	)
	add_child(portal)
	level_objects.append(portal)

# ==========================================
# ОБРАБОТКА РЕШЕНИЙ В КВЕСТАХ
# ==========================================
func trigger_dialogue(main_text: String, choices: String) -> void:
	dialogue_text.text = main_text
	dialogue_choices.text = choices
	dialogue_panel.visible = true

func handle_dialogue_choice(index: int) -> void:
	if current_location_name == \"Окраина Чернолесья\":
		dialogue_panel.visible = false
		return
		
	if current_location_name == \"Топи Кикиморы\":
		if index == 1:
			current_combat_mode = CombatMode.PEACE
			chosen_path_name = \"Святой Пацифизм\"
			can_pick_up_crystal = true
			set_boss_to_friendly()
			close_dialogue(\"Кикимора: Твои помыслы чисты. Забирай Кристалл Велеса.\")
		elif index == 2:
			chosen_path_name = \"Путь Стали и Ярости\"
			enemy_damage_modifier = 1.3
			close_dialogue(\"Леший издает яростный рев! Защищайте святыню!\")
		elif index == 3:
			chosen_path_name = \"Путь Вещего Скрытника\"
			set_enemies_to_neutral()
			close_dialogue(\"Вы скрылись в тумане. Враги нападут, только если подойти вплотную.\")
			
	elif current_location_name == \"Священная Роща\":
		if index == 1:
			current_combat_mode = CombatMode.PEACE
			chosen_path_name = \"Святой Пацифизм\"
			can_pick_up_crystal = true
			set_boss_to_friendly()
			close_dialogue(\"Верховный Кудесник: Род благословляет тебя.\")
		elif index == 2:
			chosen_path_name = \"Путь Стали и Ярости\"
			enemy_damage_modifier = 1.6
			close_dialogue(\"Стражи Рощи поднимают боевые секиры!\")
		elif index == 3:
			chosen_path_name = \"Путь Вещего Скрытника\"
			set_enemies_to_neutral()
			close_dialogue(\"Дубрава укрыла твоё присутствие.\")

	update_quest_journal()

func set_boss_to_friendly() -> void:
	for e in enemy_list:
		if is_instance_valid(e) and e.get_meta(\"id_tag\") == \"boss\":
			e.set_meta(\"status\", \"friendly\")
			e.add_to_group(\"friendly\")
			var spr = e.get_node_or_null(\"Sprite2D\")
			if spr: spr.modulate = Color(0.4, 1.0, 0.4)

func set_enemies_to_neutral() -> void:
	for e in enemy_list: if is_instance_valid(e): e.set_meta(\"status\", \"neutral\")

func close_dialogue(outcome: String) -> void:
	dialogue_text.text = outcome; dialogue_choices.text = \"\"
	await get_tree().create_timer(2.2).timeout
	dialogue_panel.visible = false

# ==========================================
# ИГРОВОЙ ЦИКЛ (ОБРАБОТКА ДВИЖЕНИЯ И ИИ)
# ==========================================
func _process(delta: float) -> void:
	if dialogue_panel.visible or current_hp <= 0: return
	
	# Контроль перемещения
	var input_dir = Vector2(Input.get_axis(\"move_left\", \"move_right\"), Input.get_axis(\"move_up\", \"move_down\")).normalized()
	if is_rolling:
		roll_timer -= delta
		player.velocity = roll_direction * roll_speed
		if roll_timer <= 0:
			is_rolling = false
			player_sprite.modulate = Color(1, 1, 1)
	else:
		player.velocity = input_dir * player_speed
		if input_dir != Vector2.ZERO:
			play_walk_animation()
			if input_dir.x != 0: player_sprite.flip_h = (input_dir.x < 0)
		else:
			reset_walk_animation()
			
	player.move_and_slide()
	
	# Обновление магии, радара карт
	var active_regen = mp_regen_speed_yav if not is_nav_world else mp_regen_speed_nav
	current_mp = min(current_mp + active_regen * delta, max_mp)
	mp_bar.value = current_mp
	
	update_minimap()
	
	if is_nav_world:
		current_nav_time -= delta
		nav_label.text = \"Навь: %.1fс\" % max(0.0, current_nav_time)
		if current_nav_time <= 0:
			switch_world(false)
			current_hp -= 20.0
			update_hp_display()
	else:
		if current_nav_time < max_nav_time: current_nav_time += delta * 0.4
			
	# Поведение Боссов и Мобов ИИ
	for enemy in enemy_list:
		if not is_instance_valid(enemy) or not enemy.visible: continue
		
		var status = enemy.get_meta(\"status\")
		if status == \"friendly\" or enemy.is_in_group(\"friendly\"):
			enemy.velocity = Vector2.ZERO; enemy.move_and_slide(); continue
			
		var distance = enemy.position.distance_to(player.position)
		var enemy_sprite = enemy.get_node_or_null(\"Sprite2D\")
		if enemy_sprite: enemy_sprite.flip_h = (player.position.x < enemy.position.x)
		
		if status == \"neutral\" and distance > 100.0:
			enemy.velocity = Vector2.ZERO; enemy.move_and_slide(); continue
			
		var cd = enemy.get_meta(\"attack_timer\")
		if cd > 0: enemy.set_meta(\"attack_timer\", cd - delta)
		var spec_cd = enemy.get_meta(\"special_attack_cd\")
		if spec_cd > 0: enemy.set_meta(\"special_attack_cd\", spec_cd - delta)
		
		if enemy.get_meta(\"id_tag\") == \"boss\":
			if current_location_name == \"Топи Кикиморы\":
				if distance > 280.0: enemy.velocity = (player.position - enemy.position).normalized() * 120.0
				elif distance < 180.0: enemy.velocity = (enemy.position - player.position).normalized() * 100.0
				else: enemy.velocity = Vector2.ZERO
				
				if spec_cd <= 0 and distance < 600.0:
					enemy.set_meta(\"special_attack_cd\", 3.0)
					cast_boss_aoe_attack(enemy.position, 4)
			elif current_location_name == \"Священная Роща\":
				enemy.velocity = (player.position - enemy.position).normalized() * 140.0
				if spec_cd <= 0 and distance < 380.0:
					enemy.set_meta(\"special_attack_cd\", 4.0)
					enemy.position = player.position + Vector2(randf_range(-140, 140), randf_range(-140, 140))
					play_hit_flash(enemy)
					cast_boss_aoe_attack(enemy.position, 6)
		else:
			enemy.velocity = (player.position - enemy.position).normalized() * 115.0 * enemy_speed_modifier
			
		enemy.move_and_slide()
		
		if distance < 75.0 and not is_rolling and enemy.get_meta(\"attack_timer\") <= 0:
			current_hp -= 20.0 * enemy_damage_modifier
			enemy.set_meta(\"attack_timer\", 1.5)
			update_hp_display()
			play_hit_flash(player)

	# Полет снарядов
	var deleted_projectiles = []
	for p in active_projectiles:
		if not is_instance_valid(p): continue
		p.position += Vector2(p.get_meta(\"dir\")) * float(p.get_meta(\"speed\")) * delta
		var life = p.get_meta(\"life\") - delta
		p.set_meta(\"life\", life)
		
		if p.get_meta(\"from_enemy\") == true:
			if p.position.distance_to(player.position) < 40.0 and not is_rolling:
				current_hp -= 15.0 * enemy_damage_modifier
				update_hp_display()
				play_hit_flash(player)
				deleted_projectiles.append(p); p.queue_free()
		else:
			for e in enemy_list:
				if is_instance_valid(e) and e.visible:
					if p.position.distance_to(e.position) < 45.0:
						if not e.is_in_group(\"friendly\"):
							inflict_damage_to_enemy(e)
							deleted_projectiles.append(p); p.queue_free()
							break
		if life <= 0 and is_instance_valid(p) and not p in deleted_projectiles:
			deleted_projectiles.append(p); p.queue_free()
	for dp in deleted_projectiles: active_projectiles.erase(dp)

func cast_boss_aoe_attack(center_pos: Vector2, projectile_count: int) -> void:
	for i in range(projectile_count):
		var angle = (PI * 2 / projectile_count) * i
		var dir = Vector2(cos(angle), sin(angle))
		var proj := Area2D.new()
		proj.position = center_pos
		proj.set_meta(\"dir\", dir); proj.set_meta(\"speed\", 320.0); proj.set_meta(\"life\", 2.0); proj.set_meta(\"from_enemy\", true)
		var spr := Sprite2D.new()
		var col = Color(0.5, 0.3, 0.1) if current_location_name == \"Топи Кикиморы\" else Color(1, 0.8, 0)
		spr.texture = load_texture_safe(\"res://spell.png\", Vector2(20, 20), col)
		proj.add_child(spr)
		var shape := CollisionShape2D.new(); shape.shape = CircleShape2D.new(); shape.shape.radius = 10.0
		proj.add_child(shape)
		add_child(proj); active_projectiles.append(proj)

# ==========================================
# ИНВЕНТАРЬ: ЛОГИКА ПОДБОРА С НАГРАДОЙ XP
# ==========================================
func collect_item_logic(item: Area2D) -> void:
	var type = item.get_meta(\"type\")
	if type == \"crystal\":
		var active_boss_exists = false
		for e in enemy_list:
			if is_instance_valid(e) and e.get_meta(\"id_tag\") == \"boss\" and not e.is_in_group(\"friendly\"):
				active_boss_exists = true
		if not can_pick_up_crystal and active_boss_exists:
			world_label.text = \"КРИСТАЛЛ ОХРАНЯЕТСЯ БОССОМ!\"
			return
		inventory[\"crystal\"] += 1
		add_xp(40) # Много опыта за кристалл
	elif type == \"herb\":
		inventory[\"herb\"] += 1
		current_hp = min(current_hp + 30.0, max_hp)
		update_hp_display()
		add_xp(20) # Опыт исследователя за нахождение травы
		
	level_objects.erase(item)
	item.queue_free()
	update_inventory_ui()
	update_quest_journal()

# ==========================================
# СИСТЕМА БЛИЖНЕГО И ДАЛЬНЕГО БОЯ
# ==========================================
func execute_attack() -> void:
	if current_combat_mode == CombatMode.PEACE or current_location_name == \"Окраина Чернолесья\": return
	attack_cooldown = true
	player_sprite.modulate = Color(1.5, 0.5, 0.5)
	player_sprite.flip_h = (get_global_mouse_position().x < player.position.x)
	
	var attack_area := Area2D.new()
	var attack_shape := CollisionShape2D.new()
	attack_shape.shape = CircleShape2D.new(); attack_shape.shape.radius = 115.0
	attack_area.add_child(attack_shape)
	player.add_child(attack_area)
	
	var attack_tween = create_tween()
	var target_offset = Vector2(-15 if player_sprite.flip_h else 15, 0)
	attack_tween.tween_property(player_sprite, \"position\", target_offset, 0.08)
	attack_tween.tween_property(player_sprite, \"position\", Vector2.ZERO, 0.1)
	
	await get_tree().create_timer(0.02).timeout
	if is_instance_valid(attack_area):
		var targets = attack_area.get_overlapping_bodies()
		for body in targets:
			if body != player and enemy_list.has(body) and not body.is_in_group(\"friendly\"):
				inflict_damage_to_enemy(body)
		attack_area.queue_free()
	
	await get_tree().create_timer(0.15).timeout
	if not is_rolling: player_sprite.modulate = Color(1, 1, 1)
	attack_cooldown = false

func execute_spell() -> void:
	if current_combat_mode == CombatMode.PEACE or current_mp < mp_spell_cost: return
	current_mp -= mp_spell_cost; mp_bar.value = current_mp
	
	var projectile := Area2D.new(); projectile.position = player.position
	var target_dir = (get_global_mouse_position() - player.position).normalized()
	projectile.set_meta(\"dir\", target_dir); projectile.set_meta(\"speed\", 750.0); projectile.set_meta(\"life\", 1.8); projectile.set_meta(\"from_enemy\", false)
	player_sprite.flip_h = (get_global_mouse_position().x < player.position.x)
	
	var spr := Sprite2D.new(); spr.texture = load_texture_safe(\"res://spell.png\", Vector2(24, 24), Color(0.2, 0.7, 1.0))
	projectile.add_child(spr)
	var shape := CollisionShape2D.new(); shape.shape = CircleShape2D.new(); shape.shape.radius = 12.0
	projectile.add_child(shape)
	add_child(projectile); active_projectiles.append(projectile)

func inflict_damage_to_enemy(enemy) -> void:
	if not is_instance_valid(enemy): return
	var hp = enemy.get_meta(\"hp\") - 20.0
	enemy.set_meta(\"hp\", hp)
	play_hit_flash(enemy)
	var push = (enemy.position - player.position).normalized() * 320.0
	var knock_tween = create_tween()
	knock_tween.tween_property(enemy, \"position\", enemy.position + push, 0.12)
	
	if hp <= 0:
		enemy_list.erase(enemy); level_objects.erase(enemy); enemy.queue_free()
		add_xp(35) # Получение опыта исследователя за победу над злом
		update_quest_journal()

func switch_world(to_nav: bool) -> void:
	is_nav_world = to_nav
	canvas_modulate.color = Color(0.3, 0.3, 0.6) if is_nav_world else Color(1.0, 1.0, 1.0)
	nav_label.visible = is_nav_world
	update_world_label_ui()
	for e in enemy_list:
		if is_instance_valid(e):
			var is_nav_enemy = e.get_meta(\"nav_only\")
			var should_display = (is_nav_world == is_nav_enemy)
			e.visible = should_display
			var coll = e.get_node_or_null(\"CollisionShape2D\")
			if coll: coll.disabled = not should_display

func start_idle_animation(sprite: Sprite2D) -> void:
	if not is_instance_valid(sprite): return
	var tween = create_tween().set_loops()
	tween.tween_property(sprite, \"scale\", Vector2(1.04, 0.96), 0.6).set_trans(Tween.TRANS_SINE)
	tween.tween_property(sprite, \"scale\", Vector2(1.0, 1.0), 0.6).set_trans(Tween.TRANS_SINE)

func play_walk_animation() -> void:
	if is_rolling or not is_instance_valid(player_sprite): return
	player_sprite.rotation = sin(Time.get_ticks_msec() * 0.01) * 0.12

func reset_walk_animation() -> void:
	if not is_rolling and is_instance_valid(player_sprite): player_sprite.rotation = 0.0

func play_hit_flash(node: Node2D) -> void:
	var sprite = node.get_node_or_null(\"Sprite2D\")
	if sprite:
		var flash_tween = create_tween(); sprite.modulate = Color(8, 0, 0)
		flash_tween.tween_property(sprite, \"modulate\", Color(1, 1, 1), 0.18)

func dir_is_moving() -> bool:
	return Input.get_axis(\"move_left\", \"move_right\") != 0 or Input.get_axis(\"move_up\", \"move_down\") != 0

func _input(event: InputEvent) -> void:
	if dialogue_panel.visible:
		if event.is_action_pressed(\"choice1\"): handle_dialogue_choice(1)
		elif event.is_action_pressed(\"choice2\"): handle_dialogue_choice(2)
		elif event.is_action_pressed(\"choice3\"): handle_dialogue_choice(3)
		return
		
	if event.is_action_pressed(\"switch_world\") and current_hp > 0: switch_world(!is_nav_world)
	if event.is_action_pressed(\"roll\") and dir_is_moving() and not is_rolling:
		is_rolling = true; roll_timer = roll_duration
		roll_direction = Vector2(Input.get_axis(\"move_left\", \"move_right\"), Input.get_axis(\"move_up\", \"move_down\")).normalized()
		player_sprite.modulate = Color(0.4, 0.6, 0.9, 0.6)
		if roll_direction.x != 0: player_sprite.flip_h = (roll_direction.x < 0)
		
	if event.is_action_pressed(\"attack\") and not attack_cooldown: execute_attack()
	if event.is_action_pressed(\"cast_spell\"): execute_spell()
"

[node name="MainGame" type="Node2D" unique_id=914802551]
script = SubResource("GDScript_mh0ok")
